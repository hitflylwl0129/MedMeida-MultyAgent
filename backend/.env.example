# ===== 腾讯云密钥（务必从环境变量读取，禁止写进代码/提交到仓库）=====
# 在 API 密钥管理页获取：https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=AKID_your_secret_id
TENCENTCLOUD_SECRET_KEY=your_secret_key

# ===== 云点播（VOD）=====
VOD_SUB_APP_ID=1500065335
VOD_REGION=ap-guangzhou

# ===== AIGC 生视频默认参数 =====
AIGC_MODEL_NAME=Kling
AIGC_MODEL_VERSION=2.1
AIGC_SCENE_TYPE=avatar_i2v
AIGC_ASPECT_RATIO=9:16
AIGC_AUDIO_GENERATION=Enabled
AIGC_INPUT_COMPLIANCE=Enabled
AIGC_OUTPUT_COMPLIANCE=Enabled
AIGC_PERSON_GENERATION=AllowAdult
AIGC_STORAGE_MODE=Temporary

# 医生形象图（首帧）VOD FileId —— 形象库优先：默认从 assets/doctors 本地素材直传，
# 此处留空即可；如需指定外部素材再填 FileId / URL（兜底）
DOCTOR_IMAGE_FILEID=
DOCTOR_IMAGE_URL=
# 默认出镜医生形象库 key：senior/middle/young _ male/female
DEFAULT_DOCTOR=middle_male

# ===== 轮询 =====
POLL_INTERVAL_SEC=10
POLL_TIMEOUT_SEC=900

# ===== 服务 =====
APP_HOST=127.0.0.1
APP_PORT=8000
# 对外可访问的基地址（用于拼成片 URL 给前端播放）：
#   - 留空：写相对路径 /api/...，浏览器按当前页 origin 自动拼。
#     ✓ 推荐：nginx 同源反代上线（http://your-server/）
#     ✓ 推荐：本地 python -m http.server 8848 反代场景
#   - 写绝对地址 http://your-server ：兼容前端用 file:// 直开 HTML 跨源场景。
PUBLIC_BASE_URL=

# ===== 视频后端开关 =====
# local         ：本地 TTS+ffmpeg 拼"医生静帧+真实口播"（默认；无需白名单）
# motion        ：腾讯云 motion_control（医生图+参考动作视频→医生动作迁移）+ 本地 TTS 拼音轨
# aigc          ：调腾讯云 CreateAigcVideoTask（avatar_i2v，需要白名单）
# kling         ：可灵原厂 API（image2video → identify-face → advanced-lip-sync）
#                 口型严格同步，嘴部幅度自然。需 KLING_ACCESS_KEY/SECRET_KEY 与公网可达地址。
# tencent_avatar：腾讯云数智人「照片免训练」（v1.3 引擎二，PoC 实测嘴形 + 女声更佳）
#                 鉴权 HMAC-SHA256(AccessToken)，全部走 URL Query
VIDEO_BACKEND=local

# ===== 可灵 Kling 原厂 API（路 A） =====
# 控制台 https://klingai.com → 创建应用拿 AK/SK（凭证仅后端持有，不入版本库）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# Kling 拉取我们暴露的"医生图/基础视频"用的公网基地址（必须可灵能访问）
# 留空则回退使用 PUBLIC_BASE_URL
KLING_PUBLIC_BASE_URL=
# image2video 造基础视频的模型与默认参数（一般不用改）
# KLING_IMAGE_MODEL=kling-v1-6
# KLING_BASE_DURATION=10
# KLING_BASE_MODE=std
# KLING_POLL_INTERVAL_SEC=10
# KLING_POLL_TIMEOUT_SEC=600

# ===== motion_control 参考视频 =====
# 文件位于 backend/assets/motion_ref/<文件名>；首次用会上传到 VOD 缓存 FileId
MOTION_REF_FILENAME=ref.mp4
# 模型/比例/轮询参数（一般不用改）
# MOTION_MODEL_NAME=Kling
# MOTION_MODEL_VERSION=2.1
# MOTION_ASPECT_RATIO=9:16
# MOTION_POLL_INTERVAL_SEC=6
# MOTION_POLL_TIMEOUT_SEC=600


# ===== 本地链路缓存 =====
# backend/.cache/jobs/ 下保留最近 N 个任务目录（0=不清理）
LOCAL_KEEP_JOBS=20

# ===== 字幕烧录（可选） =====
# brew 默认 ffmpeg 未编译 libass，画面无字幕；要字幕请装 ffmpeg-full：
#   brew install ffmpeg-full
# 装好后开下面这行（指向 ffmpeg-full 的 ffmpeg；composer 会自动同目录用 ffprobe）
# FFMPEG_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg

# ===== LLM（话术 Agent，OpenAI 兼容） =====
LLM_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
LLM_API_KEY=请到腾讯云控制台申请
LLM_MODEL=hy3-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=600
LLM_TIMEOUT_SEC=60

# ===== B站投稿（短视频分发 Agent · Web 投稿 Cookie 鉴权） =====
# 浏览器登录 bilibili.com → F12 → Application → Cookies，复制 SESSDATA 与 bili_jct。
# ⚠️ 账号级敏感凭证，仅后端持有；切勿提交到版本库 / 下发前端。SESSDATA 约 5 天过期需更新。
BILI_SESSDATA=
BILI_JCT=
BILI_BUVID3=
# 默认分区：知识区→科学科普(201)
BILI_DEFAULT_TID=201
BILI_DEFAULT_TAG=健康科普,科普,养生
# 1=仅自己可见(安全默认) / 0=公开
BILI_ONLY_SELF=1

# ===== 腾讯云数智人「照片免训练」（v1.3 引擎二）=====
# 控制台 https://xiaowei.cloud.tencent.com/ivh#/asserts_management
# 鉴权规范 https://cloud.tencent.com/document/product/1240/107197
# PoC 实测：嘴形精度 > Kling，female_1 听感优秀；输出竖屏 800×1184 / 1184×1760
# 试用账号并发=1，生产前要购独享并发包
TENCENT_AVATAR_APP_KEY=
TENCENT_AVATAR_ACCESS_TOKEN=
# 默认音色（医生具体音色 → backend/app/doctors.py 的 avatar_timbre_for_doctor）
TENCENT_AVATAR_DEFAULT_TIMBRE=male_1
# 接口 TTS 实测比 Kling 慢 ~31%，1.2 倍速恰好对齐
TENCENT_AVATAR_SPEECH_SPEED=1.2
# 720P / 1080P（内部转 int 0/1；输出真实分辨率分别为 800×1184 / 1184×1760）
TENCENT_AVATAR_RESOLUTION=720P
# 轮询与重试
TENCENT_AVATAR_POLL_INTERVAL_SEC=8
TENCENT_AVATAR_POLL_TIMEOUT_SEC=900
TENCENT_AVATAR_SUBMIT_RETRIES=6
TENCENT_AVATAR_SUBMIT_RETRY_INTERVAL_SEC=30
# 后处理目标比例（cover=中心裁切 9:16 / pad=上下补黑）
TENCENT_AVATAR_TARGET_ASPECT=9:16
TENCENT_AVATAR_FIT_MODE=cover

# ===== 腾讯云 Agent Runtime（选品 Agent 沙箱）=====
# 控制台：https://console.cloud.tencent.com/ags/sandbox?rid=1
# 文档：https://cloud.tencent.com/document/product/1814/132250
# 工程文档：选品Agent_AgentRuntime技术路线分析.md
#
# 使用前提：
#   1) 在控制台创建 1 个 API Key（只显示一次，立刻保存）
#   2) 创建 2 个沙箱工具：
#      - 代码沙箱（codeinterpreter 类型，公网模式，名称如 code-medmedia-v1）
#      - 浏览器沙箱（browser 类型，公网模式，名称如 browser-medmedia-v1）
AGR_ENABLED=false
E2B_DOMAIN=ap-guangzhou.tencentags.com
E2B_API_KEY=ark_请到控制台创建并立即复制
AGR_TEMPLATE_CODE=code-medmedia-v1
AGR_TEMPLATE_BROWSER=browser-medmedia-v1
# 单个沙箱实例最长存续时间（秒），与控制台 Tool 生命周期上限一致
AGR_DEFAULT_TIMEOUT_SEC=3600
# 单次 run_code 超时（秒）
AGR_CODE_RUN_TIMEOUT_SEC=600
